{
  "name": "overlord-server",
  "version": "1.8.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run build:css && bun run src/index.ts",
    "build": "bun run build:css && bun build --production --minify src/index.ts --target bun --outdir dist",
    "build:prod:win": "bun build --production --minify src/index.ts --compile --target bun-windows-x64 --outfile dist/overlord-server.exe",
    "build:prod:linux": "bun build --production --minify src/index.ts --compile --target bun-linux-x64 --outfile dist/overlord-server-linux-x64",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/assets/tailwind.css --watch"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@solana/web3.js": "^1.98.4",
    "adm-zip": "^0.5.12",
    "flag-icons": "latest",
    "geoip-lite": "latest",
    "jose": "^6.1.3",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "^1.3.9",
    "@types/geoip-lite": "latest",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.3"
  }
}
