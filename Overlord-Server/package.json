{
  "name": "overlord-server",
  "version": "1.8.14",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run build:css && bun run vendor && bun run src/index.ts",
    "build": "bun run build:css && bun run vendor && bun build --production --external sharp src/index.ts --target bun --outdir dist",
    "vendor": "bun run scripts/vendor.ts",
    "build:prod:win": "bun build --production --external sharp src/index.ts --compile --target bun-windows-x64 --outfile dist/overlord-server.exe",
    "build:prod:linux": "bun build --production --external sharp src/index.ts --compile --target bun-linux-x64 --outfile dist/overlord-server-linux-x64",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/assets/tailwind.css --watch",
    "minify": "bun run scripts/minify-public.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fortawesome/fontawesome-free": "6.5.2",
    "@msgpack/msgpack": "^3.0.0",
    "@solana/web3.js": "^1.98.4",
    "ace-builds": "1.36.5",
    "adm-zip": "^0.5.12",
    "animejs": "3.2.2",
    "ansi-to-html": "0.7.2",
    "chart.js": "4.4.0",
    "codemirror": "5.65.16",
    "flag-icons": "latest",
    "geoip-lite": "latest",
    "highlight.js": "11.9.0",
    "jose": "^6.1.3",
    "leaflet": "1.9.4",
    "msgpackr": "1.11.8",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "^1.3.9",
    "@types/geoip-lite": "latest",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.23",
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.1",
    "typescript": "^5.6.3"
  }
}
